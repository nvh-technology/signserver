<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <system.webServer>
        <defaultDocument>
            <files>
                <add value="index.php" />
            </files>
        </defaultDocument>
        <!-- Tắt MultiViews và Indexes -->
        <directoryBrowse enabled="false" />
        <security>
            <!-- Bảo vệ tệp .env -->
            <requestFiltering>
                <hiddenSegments>
                    <add segment=".env" />
                </hiddenSegments>
                <requestLimits maxQueryString="4096" />
            </requestFiltering>
        </security>
        <rewrite>
            <rules>
                <!-- Xử lý Header Authorization -->
                <rule name="Authorization Header">
                    <match url=".*" />
                    <conditions>
                        <add input="{HTTP_AUTHORIZATION}" pattern="." />
                    </conditions>
                    <action type="Rewrite" url="{R:0}" />
                    <serverVariables>
                        <set name="HTTP_AUTHORIZATION" value="{HTTP_AUTHORIZATION}" />
                    </serverVariables>
                </rule>
                <!-- Redirect Trailing Slashes nếu không phải là thư mục -->
                <rule name="Redirect Trailing Slashes" stopProcessing="true">
                    <match url="(.*)/$" />
                    <conditions>
                        <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
                    </conditions>
                    <action type="Redirect" url="{R:1}" redirectType="Permanent" />
                </rule>
                <!-- Xử lý Front Controller (định tuyến đến index.php) -->
                <rule name="Front Controller" stopProcessing="true">
                    <match url="^(?!.*\.(css|js|png|jpg|jpeg|gif|ico|woff|woff2|ttf|svg|robots\.txt)$).*" />
                    <conditions logicalGrouping="MatchAll">
                        <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
                        <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
                    </conditions>
                    <action type="Rewrite" url="index.php" />
                </rule>
                <!-- Xử lý tài nguyên trong thư mục public -->
                <rule name="Public Resource Handler" stopProcessing="true">
                    <match url="^(css|assets|market_assets|images|landing|uploads|storage|installer|js|vendor)/(.*)$" />
                    <conditions logicalGrouping="MatchAll">
                        <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
                        <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
                        <add input="{REQUEST_URI}" pattern="^/public/" negate="true" />
                    </conditions>
                    <action type="Rewrite" url="public/{R:0}" />
                </rule>
            </rules>
        </rewrite>
        <handlers>
            <add name="PHP_FastCGI" path="*.php" verb="*" modules="CgiModule" scriptProcessor="C:\php82\php-cgi.exe" resourceType="File" />
        </handlers>
    </system.webServer>
</configuration>
